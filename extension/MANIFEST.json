{
  "manifest_version": 3,
  "name": "P.A.T.C.H Worker Assist",
  "version": "1.0",
  "description": "Local analysis tool for youth outreach workers.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "sandbox": {
    "pages": [
      "sandbox.html"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "models/mental-health-bert-finetuned-onnx/model_optimized.onnx",
        "models/mental-health-bert-finetuned-onnx/vocab.txt",
        "onnx-wasm/ort-wasm-simd-threaded.wasm",
        "onnx-wasm/ort-wasm-simd-threaded.mjs"
      ],
      "matches": [
        "https://www.instagram.com/*"
      ]
    },
    {
      "resources": [
        "offscreen.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "P.A.T.C.H Worker Assist"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "dist/background.bundle.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ]
}